<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Dakshesha's Web Portal</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <style>
    body { font-family: Arial, sans-serif; margin:0; background:#f4f4f4; }
    header { background:#333; color:#fff; padding:20px; text-align:center; }
    nav { background:#444; display:flex; justify-content:center; }
    nav a { color:#fff; padding:14px 20px; text-decoration:none; }
    nav a:hover { background:#666; }
    section { padding:40px; }
    .hero { background:#009688; color:#fff; text-align:center; padding:60px; }
    .grid { display:grid; grid-template-columns:repeat(3,1fr); gap:20px; }
    .card { background:#fff; padding:20px; border-radius:8px; box-shadow:0 2px 5px rgba(0,0,0,0.2); }
    footer { background:#333; color:#fff; text-align:center; padding:20px; }
    button, a.contact-btn { 
      background:#009688; 
      color:#fff; 
      border:none; 
      padding:10px 20px; 
      cursor:pointer; 
      text-decoration:none; 
      border-radius:5px;
      display:inline-block;
      margin:5px;
    }
    button:hover, a.contact-btn:hover { background:#00796B; }
  </style>
</head>
<body>

<header>
  <h1>Welcome to My Complex Website</h1>
  <p>HTML + CSS + Interactive Elements</p>
</header>

<nav>
  <a href="#home">Home</a>
  <a href="#services">Services</a>
  <a href="#about">About</a>
  <a href="#contact">Contact</a>
</nav>

<section id="home" class="hero">
  <h2>Hero Section</h2>
  <p>This is a bold introduction area with a call-to-action.</p>
  <button onclick="alert('Thanks for clicking!')">Click Me</button>
</section>

<section id="services">
  <h2>Our Services</h2>
  <div class="grid">
    <div class="card">
      <h3>Web Development</h3>
      <p>Building responsive and modern websites.</p>
    </div>
    <div class="card">
      <h3>AI Solutions</h3>
      <p>Integrating artificial intelligence into workflows.</p>
    </div>
    <div class="card">
      <h3>Consulting</h3>
      <p>Helping businesses grow with technology.</p>
    </div>
  </div>
</section>

<section id="about">
  <h2>About Us</h2>
  <p>We are a team of developers and designers passionate about creating digital experiences.</p>
</section>

<section id="contact">
  <h2>Contact Us</h2>
  <p>You can reach me directly:</p>
  <!-- Email button -->
  <a class="contact-btn" href="mailto:daksheshak@gmail.com">Email Me</a>
  <!-- Phone call button -->
  <a class="contact-btn" href="tel:7829138999">Call Me</a>
</section>

<footer>
  <p>&copy; 2026 Dakshesha's Website | All Rights Reserved</p>
</footer>

</body>
</html>
